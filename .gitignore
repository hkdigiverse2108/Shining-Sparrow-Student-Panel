# =============================================
# Shining-Sparrow Student Panel — .gitignore
# Vite + React 19 + TypeScript + TailwindCSS
# =============================================

# ── Dependencies ──────────────────────────────
node_modules/
.pnp
.pnp.js

# ── Build Outputs ─────────────────────────────
dist/
dist-ssr/
build/
out/

# ── Environment & Secrets ─────────────────────
# NEVER commit .env files — they contain private API URLs & keys
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local
.env.staging
.env.staging.local
*.env

# ── TypeScript Build Cache ────────────────────
*.tsbuildinfo
tsconfig.tsbuildinfo

# ── Vite Cache ────────────────────────────────
.vite/
vite.config.ts.timestamp-*

# ── Logs ──────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ── Testing & Coverage ────────────────────────
coverage/
.nyc_output/

# ── Editor & IDE ──────────────────────────────
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
.DS_Store
Thumbs.db

# ── OS Generated ──────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── Misc ──────────────────────────────────────
*.local
.antigravityignore
package-lock.json